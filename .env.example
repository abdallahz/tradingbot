# TradingBot environment variables for local/cloud deployment
# Copy to .env (local only) or set directly in your cloud provider.

# Alpaca credentials
ALPACA_API_KEY=YOUR_ALPACA_API_KEY
ALPACA_API_SECRET=YOUR_ALPACA_SECRET_KEY
ALPACA_PAPER=true

# News toggles
NEWS_SEC_FILINGS=true
NEWS_RSS_FEEDS=true
NEWS_EARNINGS_CALENDAR=true
NEWS_PRESS_RELEASES=true
NEWS_SOCIAL_PROXY_ENABLED=true
NEWS_TWITTER_ENABLED=false
NEWS_REDDIT_ENABLED=false

# Optional API values
TWITTER_BEARER_TOKEN=
SEC_USER_AGENT=TradingBot/1.0 (you@example.com)
NEWS_MAX_AGE_HOURS=24
